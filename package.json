{
  "name": "nomad-drive-backend",
  "version": "1.0.0",
  "description": "Nomad Drive Backend API - TypeScript + Node.js + MariaDB",
  "author": "Vitor Azevedo Paiva",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenvx run -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "dotenvx run -- prisma generate",
    "prisma:migrate": "dotenvx run -- prisma migrate dev",
    "prisma:migrate:prod": "dotenvx run -- prisma migrate deploy",
    "prisma:studio": "dotenvx run -- prisma studio",
    "prisma:seed": "dotenvx run -- tsx prisma/seed.ts",
    "test": "jest"
  },
  "dependencies": {
    "@clerk/express": "^2.0.4",
    "@dotenvx/dotenvx": "^1.55.1",
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "morgan": "^1.10.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9",
    "@types/morgan": "^1",
    "@types/node": "^25.5.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.6.0"
}
