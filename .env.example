# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/your-database

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Clerk Configuration (OAuth/SSO)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# OneSignal
ONESIGNAL_APP_ID="your-app-id-here"
ONESIGNAL_REST_API_KEY="your-rest-api-key-here"

# CORS Configuration
CORS_ORIGIN=http://localhost:8081,exp://192.168.1.100:8081

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100      # global limit WITH fingerprint
RATE_LIMIT_STRICT_MAX=30         # global limit WITHOUT fingerprint
RATE_LIMIT_AUTH_MAX=10           # login + forgot-password limit


# Logging
LOG_LEVEL=debug

# Email Configuration (Optional - for password reset, notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=Nomad Drive <noreply@yourdomain.com>

# cPanel Deployment Configuration
CPANEL_USER=your_cpanel_username
CPANEL_DOMAIN=yourdomain.yourdomain.com

# Admin pass for seed
ADMIN_PASS=your_pass_for_seed
