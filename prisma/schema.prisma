generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== USERS ====================
model User {
  id           String  @id @default(uuid())
  clerkId      String? @unique @map("clerk_id")
  name         String
  lastName     String  @map("last_name")
  email        String  @unique
  password     String? // Nullable for OAuth users
  phone        String?
  role         Role    @default(USER)
  profileImage String? @map("profile_image")

  // --- User configurations ---
  useLocalAuthentication Boolean @default(false) @map("use_local_authentication")
  skipWelcomeScreen      Boolean @default(false) @map("skip_welcome_screen")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  rentals Rental[]

  @@index([email])
  @@index([clerkId])
  @@index([role])
  @@map("users")
}

enum Role {
  ADMIN
  USER

  @@map("role")
}

// ==================== OWNERS (PARTNERS/OWNERS) ====================
model Owner {
  id       String  @id @default(uuid())
  name     String
  phone    String
  email    String?
  document String? @unique // CPF or CNPJ

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  vehicles Vehicle[]

  @@map("owners")
}

// ==================== VEHICLES ====================
model Vehicle {
  id                String           @id @default(uuid())
  type              VehicleType      @default(QUADRICYCLE)
  brand             String
  model             String
  year              Int
  color             String
  description       String?
  passengerCapacity Int
  transmission      TransmissionType
  has4x4            Boolean          @default(false) @map("has_4x4")
  licensePlate      String           @unique @map("license_plate")
  dailyRate         Decimal          @map("daily_rate")
  status            VehicleStatus    @default(AVAILABLE)
  isActive          Boolean          @default(true) @map("is_active")
  ownerId           String?          @map("owner_id")
  blockedDaysOfWeek Json?            @map("blocked_days_of_week") // Eg: [0, 1] or ["SUNDAY"]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  owner   Owner?         @relation(fields: [ownerId], references: [id])
  rentals Rental[]
  images  VehicleImage[]

  @@index([status])
  @@index([type])
  @@index([isActive])
  @@index([status, isActive])
  @@index([ownerId])
  @@map("vehicles")
}

// ==================== VEHICLE IMAGES ====================
model VehicleImage {
  id           String  @id @default(uuid())
  vehicleId    String  @map("vehicle_id")
  imageUrl     String  @map("image_url")
  isPrimary    Boolean @default(false) @map("is_primary")
  displayOrder Int     @default(0) @map("display_order")
  caption      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([vehicleId, isPrimary])
  @@index([vehicleId, displayOrder])
  @@map("vehicle_images")
}

enum VehicleType {
  QUADRICYCLE
  BUGGY
  UTV
  SUV
}

enum TransmissionType {
  MANUAL
  SEMI_AUTOMATIC
  AUTOMATIC
}

enum VehicleStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  UNAVAILABLE
  BLOCKED_BY_OWNER
}

// ==================== RENTALS (ORDERS) ====================
model Rental {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  vehicleId  String       @map("vehicle_id")
  startDate  DateTime     @map("start_date")
  endDate    DateTime     @map("end_date")
  totalPrice Decimal      @map("total_price")
  status     RentalStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([vehicleId, status, startDate, endDate])
  @@map("rentals")
}

enum RentalStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}
